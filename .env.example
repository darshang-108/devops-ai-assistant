# ── LLM Configuration ────────────────────────────────────────────────────────
# Anthropic Claude API key (required for LLM answers)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── GitHub API (optional but recommended for higher rate limits) ─────────────
GITHUB_TOKEN=ghp_your_token_here

# ── Security (comma-separated API keys) ─────────────────────────────────────
# Leave empty to run in dev mode (no auth required)
API_KEYS=

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT=10/minute

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
